# Copy to `.env.local` for local development (Next.js loads it automatically).
# Values come from Firebase Console → Project settings → Your apps → Web app config.

# --- Firebase Web SDK (client) — all required for Auth / Firestore / Storage in the browser ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=nonprofithq
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Optional: measurement / analytics (if you add Firebase Analytics later) ---
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# --- Optional: local emulators (not wired in `src/services/firebase/client.ts` yet) ---
# After connecting emulators in code, you might use e.g.:
# NEXT_PUBLIC_USE_FIREBASE_EMULATORS=true
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
# FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
# FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199

# --- Seed / Admin scripts (Node, not Next.js) — see docs/SETUP.md ---
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccount.json
# GCLOUD_PROJECT=your-project-id
